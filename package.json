{
  "name": "swiftride-ai",
  "version": "1.0.0",
  "private": true,
  "description": "Swiftride AI monorepo - real-time dispatch platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "nodemon --watch apps/api --exec ts-node apps/api/src/index.ts",
    "dev:socket": "nodemon --watch apps/socket --exec ts-node apps/socket/src/index.ts",
    "dev:worker": "nodemon --watch apps/worker --exec ts-node apps/worker/src/cleanup.job.ts",
    "dev:surge-worker": "nodemon apps/worker/src/surge.worker.ts",
    "dev:all": "concurrently -k -n API,SOCKET,WORKER \"npm run dev:api\" \"npm run dev:socket\" \"npm run dev:worker\"",
    "build": "tsc -b",
    "start:api": "node apps/api/dist/index.js",
    "start:socket": "node apps/socket/dist/index.js",
    "start:worker": "node apps/worker/dist/cleanup.job.js",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "download:osm": "docker-compose run osrm-download",
    "db:migrate": "psql $DATABASE_URL < packages/database/schema.sql",
    "clean": "rm -rf node_modules package-lock.json apps/**/dist packages/**/dist",
    "install:clean": "npm run clean && npm install",
    "precache:routes": "curl -X POST http://localhost:3001/api/routing/precache",
    "test:tracking": "bash scripts/test-tracking.sh",
    "test:surge": "bash scripts/test-surge.sh",
    "scale:up": "docker compose -f docker-compose.scale.yml up -d",
    "scale:down": "docker compose -f docker-compose.scale.yml down",
    "scale:ps": "docker compose -f docker-compose.scale.yml ps",
    "scale:logs": "docker compose -f docker-compose.scale.yml logs -f",
    "scale:api": "docker compose -f docker-compose.scale.yml up -d --scale api=5",
    "scale:socket": "docker compose -f docker-compose.scale.yml up -d --scale socket=3",
    "cluster:init": "docker exec -it redis-node-1 redis-cli --cluster create redis-node-1:6379 redis-node-2:6379 redis-node-3:6379 redis-node-4:6379 redis-node-5:6379 redis-node-6:6379 --cluster-replicas 1",
    "test:scale": "./scripts/run-full-scale-test.sh",
    "build:api": "tsc -b apps/api/tsconfig.json --incremental",
  "build:socket": "tsc -b apps/socket/tsconfig.json --incremental",
  "build:worker": "tsc -b apps/worker/tsconfig.json --incremental"
    },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.40",
    "@types/pg": "^8.20.0",
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@stripe/react-stripe-js": "^6.3.0",
    "@stripe/stripe-js": "^9.4.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "socket.io": "^4.6.2",
    "socket.io-client": "^4.6.2",
    "stripe": "^22.1.1",
    "uuid": "^14.0.0"
  }
}
